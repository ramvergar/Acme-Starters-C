acme.validation.header.message  	= Debe tener entre 1 y 75 caracteres
acme.validation.text.message   		= Debe tener entre 1 y 255 caracteres 
acme.validation.ticker.message			   = La referencia sólo puede contener letras, dígitos, subrayados y guiones

# Invention ############################################################
acme.validation.invention.parts.message = La invención debe tener al menos una parte
acme.validation.invention.dates.message = Para publicar un invento, ambas fechas deben estar en el futuro
acme.validation.invention.ticker.non-unique = El ticker ya está en uso por otro invento
acme.validation.invention.monthsActive.message = Los meses activos no pueden ser negativos o nulos
acme.validation.invention.cost.message = El coste debe ser un valor positivo en EUR
acme.validation.invention.parts.message = El coste de las partes debe estar en EUR
acme.validation.invention.timeInterval.message = El intervalo de tiempo es incorrecto

# Campaign ######################################################

spokesperson.campaign.form.error.duplicated-ticker = El código ya existe.
spokesperson.campaign.form.error.invalid-period = La fecha de fin debe ser posterior a la fecha de inicio.
spokesperson.campaign.form.error.no-milestones = Una campaña debe tener al menos un hito antes de ser publicada.
# Strategy ######################################################
acme.validation.strategy.duplicated-ticker.message = La Estrategia está duplicada
acme.validation.strategy.tactics.error.message = Una Estrategia no puede publicarse a menos que tenga al menos una táctica
acme.validation.strategy.dates.error = Las fechas de inicio y fin deben definir un intervalo válido de tiempo
acme.validation.strategy.startMoment.future = La fecha de inicio debe estar en el futuro
acme.validation.strategy.endMoment.future = La fecha de fin debe estar en el futuro

acme.validation.tactic.sumPercentages = La suma de los porcentajes de las tácticas tiene que ser menor o igual que 100.00.

#Sponsor ############################
# Sponsorship ####################

acme.validation.sponsorship.duplicated-ticker.message = Ya existe un patrocinio con esta referencia
acme.validation.sponsorship.timeInterval.message = Las fechas de inicio y fin deben tener un momento válido
acme.validation.sponsorship.donations.message = Un patrocinio no puede ser publicado a no ser que tengan una donación

# Donation #######################
acme.validation.donation.money.currency.message = La moneda de la donación debe ser en Euros (EUR)
