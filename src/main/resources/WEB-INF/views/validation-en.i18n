acme.validation.header.message  	= Must have from 1 to 75 characters
acme.validation.text.message   		= Must have from 1 to 255 characters
acme.validation.ticker.message 		= The ticker must have letters, digits, underscores, and hyphens only. The pattern is "^[A-Z]{2}[0-9]{2}-\\w{5,10}$"

# Invention ############################################################
acme.validation.invention.parts.message = The invention must have at least one part
acme.validation.invention.dates.message = To publish an invention, both dates must be in the future
acme.validation.invention.ticker.non-unique = The ticker is already used by another invention
acme.validation.invention.monthsActive.message = The active months cannot be negative or null
acme.validation.invention.cost.message = The cost must be a positive value in EUR
acme.validation.invention.parts.message = The currency of the parts must be EUR
acme.validation.invention.timeInterval.message = The time interval is incorrect

# Campaign ############################################################
spokesperson.campaign.form.error.duplicated-ticker = The ticker already exists.
spokesperson.campaign.form.error.invalid-period = The end moment must be after the start moment.
spokesperson.campaign.form.error.no-milestones = A campaign must have at least one milestone before publishing.
acme.validation.campaign.invalid-interval = Start/end moments must define a valid future time interval
acme.validation.campaign.effort-not-positive = The campaign effort must be positive when published
acme.validation.campaign.startMoment.future     = Start date must be in the future
acme.validation.campaign.endMoment.future       = End date must be in the future
acme.validation.campaign.dates.error-publish = Start/end moments must define a valid time interval

# Strategy #############################################################
acme.validation.strategy.duplicated-ticker.message = The strategy is duplicated
acme.validation.strategy.tactics.error.message = A Strategy cannot be published unless they have at least one tactic
acme.validation.strategy.dates.error = Start/end moments must define a valid time interval
acme.validation.strategy.startMoment.future = Start date must be in the future
acme.validation.strategy.endMoment.future = End date must be in the future

acme.validation.tactic.sumPercentages = The sum of the percentages of the tactics must be lower or equal than 100.00

#Sponsor ############################
# Sponsorship ####################

acme.validation.sponsorship.duplicated-ticker.message = There is an existing sponsorship with this ticker
acme.validation.sponsorship.timeInterval.message = Start moment must be before end moment
acme.validation.sponsorship.donations.message = A Sponsorship can not be published unless they have at least one donation

# Donation #######################
acme.validation.donation.money.currency.message = Donation currency must be Euro (EUR)
